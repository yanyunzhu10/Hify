# Hify local deployment environment template
#
# Usage after extracting the tarball:
#   cp env.template .env
#   vi .env
#   ./bin/start.sh

# ===== App =====
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS="-Xms512m -Xmx1g"
STARTUP_TIMEOUT=60
GRACEFUL_TIMEOUT=30

# ===== MySQL =====
MYSQL_URL="jdbc:mysql://127.0.0.1:3306/hify?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&rewriteBatchedStatements=true"
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=""

# ===== PostgreSQL + pgvector =====
PGVECTOR_URL="jdbc:postgresql://127.0.0.1:5432/hify"
PGVECTOR_USERNAME=postgres
PGVECTOR_PASSWORD=change-me

# ===== Upload / embedding =====
HIFY_UPLOAD_DIR=./upload
EMBEDDING_ENABLED=false
EMBEDDING_BASE_URL=""
EMBEDDING_API_KEY=""
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
